<launch>

    <!-- 设置参数 -->
    <!-- <param name="robot_description" textfile="$(find biped_rviz)/urdf/urdf/biped_robot.urdf" /> -->
    <param name="robot_description" textfile="$(find biped_rviz)/robot_properties_bolt/src/robot_properties_bolt/resources/xacro/bolt_humanoid.xacro" />
    
    <!-- <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher" /> -->
    <!-- 添加机器人状态发布节点 -->
    <!-- <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" /> -->

    <!-- 启动 gazebo -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch" />

    <!-- 在 gazebo 中显示机器人模型 -->
    <node pkg="gazebo_ros" type="spawn_model" name="model" args="-urdf -model mycar -param robot_description"  />

    <!-- 启动 rviz -->
    <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find biped_rviz)/config/show.rviz"/> -->

</launch>