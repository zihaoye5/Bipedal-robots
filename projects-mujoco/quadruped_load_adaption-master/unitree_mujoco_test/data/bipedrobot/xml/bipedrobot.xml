<mujoco model="bolt">
  <compiler angle="radian" meshdir="../meshes/"/>
  <size njmax="500" nconmax="100" />
  <option gravity='0 0 -9.806' iterations='50' solver='Newton' timestep='0.005'/>
  <default>
        <geom contype="1" conaffinity="1" friction="1 0.3 0.3" rgba="0.5 0.6 0.7 1" margin="0.001" group="0"/>

        <light castshadow="false" diffuse="1 1 1"/>
        <motor ctrlrange="-33.5 33.5" ctrllimited="true"/>
        <camera fovy="60"/>
        <joint damping="0.00" armature="0.0" frictionloss="0.0"/>
    
  </default>

  <asset>
    <mesh name="bolt_body" file="bolt_body.stl"/>
    <mesh name="bolt_hip_fe_left_side" file="bolt_hip_fe_left_side.stl"/>
    <mesh name="upper_leg_200mm_left_side" file="upper_leg_200mm_left_side.stl"/>
    <mesh name="lower_leg_200mm_left_side" file="lower_leg_200mm_left_side.stl"/>
    <mesh name="bolt_foot" file="bolt_foot.stl"/>
    <mesh name="bolt_hip_fe_right_side" file="bolt_hip_fe_right_side.stl"/>
    <mesh name="upper_leg_200mm_right_side" file="upper_leg_200mm_right_side.stl"/>
    <mesh name="lower_leg_200mm_right_side" file="lower_leg_200mm_right_side.stl"/>
  </asset>

  <asset>
      <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
      <texture type="2d" name="plane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
    markrgb="0.8 0.8 0.8" width="300" height="300"/>
      <material name="plane" reflectance="0.0" texture="plane" texrepeat="3 3"  texuniform="true"/>
  </asset>

  <visual>
      <rgba com="0.502 1.0 0 0.5" contactforce="0.98 0.4 0.4 0.7" contactpoint="1.0 1.0 0.6 0.4"/>
      <scale com="0.2" forcewidth="0.035" contactwidth="0.10" contactheight="0.04"/>
  </visual>

  <worldbody>
    <light directional="true" diffuse=".8 .8 .8" pos="0 0 10" dir="0 0 -10"/>
    <camera name="track" mode="trackcom" pos="0 -1.3 1.6" xyaxes="1 0 0 0 0.707 0.707"/>
    <geom name='floor' type='plane' conaffinity='1' condim='3' contype='1' rgba="0.5 0.9 0.9 0.1" material='plane' pos='0 0 0' size='0 0 1'/>

    <body name="base_link" pos="0 0 0.5">
      <inertial pos="0 0 0" quat="0 0.707107 0 0.707107" mass="0.615369" diaginertia="0.0248612 0.0193821 0.00588574"/>
      <joint type="free" limited="false" actuatorfrclimited="false"/>
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="bolt_body"/>
      <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="bolt_body"/>
      <site name="imu" pos="0 0 0"/>

      <body name="FL_SHOULDER" pos="0 0.0636 0">
        <inertial pos="0.0170826 -0.00446892 -0.0109583" quat="0.380445 0.573263 0.68117 0.250275" mass="0.140043" diaginertia="0.000140999 0.000103321 5.85997e-05"/>
        <joint name="FL_HAA" pos="0 0 0" axis="1 0 0" range="-0.802851 0.802851" actuatorfrcrange="-2.7 2.7"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="bolt_hip_fe_left_side"/>
        <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="bolt_hip_fe_left_side"/>
        <body name="FL_UPPER_LEG" pos="0 0.0145 -0.0386">
          <inertial pos="1.377e-05 0.0193585 -0.118707" quat="0.705243 -0.0424536 0.0423607 0.706424" mass="0.148538" diaginertia="0.000417563 0.00041107 2.46069e-05"/>
          <joint name="FL_HFE" pos="0 0 0" axis="0 1 0" range="-6.28 6.28" actuatorfrcrange="-2.7 2.7"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="upper_leg_200mm_left_side"/>
          <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="upper_leg_200mm_left_side"/>
          <body name="FL_LOWER_LEG" pos="0 0.0374 -0.2">
            <inertial pos="0 0.00836601 -0.116186" quat="0.707082 -0.00588079 0.00588079 0.707082" mass="0.0312724" diaginertia="0.00011713 0.000116139 2.69836e-06"/>
            <joint name="FL_KFE" pos="0 0 0" axis="0 1 0" range="-6.28 6.28" actuatorfrcrange="-2.7 2.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="lower_leg_200mm_left_side"/>
            <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="lower_leg_200mm_left_side"/>
            <geom pos="0 0.008 -0.21" quat="0.385543 0 0.92269 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="bolt_foot"/>
            <geom pos="0 0.008 -0.21" quat="0.385543 0 0.92269 0" type="mesh" rgba="0.8 0.8 0.8 1" mesh="bolt_foot"/>
          </body>
        </body>
      </body>
      <body name="FR_SHOULDER" pos="0 -0.0636 0">
        <inertial pos="0.0170823 0.00447099 -0.0109585" quat="0.250376 0.681095 0.573344 0.380393" mass="0.140044" diaginertia="0.000141003 0.000103316 5.8591e-05"/>
        <joint name="FR_HAA" pos="0 0 0" axis="1 0 0" range="-0.802851 0.802851" actuatorfrcrange="-2.7 2.7"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="bolt_hip_fe_right_side"/>
        <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="bolt_hip_fe_right_side"/>
        <body name="FR_UPPER_LEG" pos="0 -0.0145 -0.0386">
          <inertial pos="-1.377e-05 -0.0193585 -0.118707" quat="0.705243 0.0424536 -0.0423607 0.706424" mass="0.148538" diaginertia="0.000417563 0.00041107 2.46069e-05"/>
          <joint name="FR_HFE" pos="0 0 0" axis="0 1 0" range="-6.28 6.28" actuatorfrcrange="-2.7 2.7"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="upper_leg_200mm_right_side"/>
          <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="upper_leg_200mm_right_side"/>
          <body name="FR_LOWER_LEG" pos="0 -0.0374 -0.2">
            <inertial pos="0 -0.00836601 -0.116186" quat="0.707082 0.00588079 -0.00588079 0.707082" mass="0.0312724" diaginertia="0.00011713 0.000116139 2.69836e-06"/>
            <joint name="FR_KFE" pos="0 0 0" axis="0 1 0" range="-6.28 6.28" actuatorfrcrange="-2.7 2.7"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="lower_leg_200mm_right_side"/>
            <geom type="mesh" rgba="0.8 0.8 0.8 1" mesh="lower_leg_200mm_right_side"/>
            <geom pos="0 -0.008 -0.21" quat="0.385543 0 0.92269 0" type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.8 0.8 0.8 1" mesh="bolt_foot"/>
            <geom pos="0 -0.008 -0.21" quat="0.385543 0 0.92269 0" type="mesh" rgba="0.8 0.8 0.8 1" mesh="bolt_foot"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>       

    <motor name="FL_SHOULDER" gear="1" ctrllimited="true" ctrlrange="-20 20" joint="FL_HAA"/>
    <motor name="FL_UPPER_LEG" gear="1" ctrllimited="true" ctrlrange="-55 55" joint="FL_HFE"/>
    <motor name="FL_LOWER_LEG" gear="1" ctrllimited="true" ctrlrange="-55 55" joint="FL_KFE"/>
    <motor name="FR_SHOULDER" gear="1" ctrllimited="true" ctrlrange="-20 20" joint="FR_HAA"/>
    <motor name="FR_UPPER_LEG" gear="1" ctrllimited="true" ctrlrange="-55 55" joint="FR_HFE"/>
    <motor name="FR_LOWER_LEG" gear="1" ctrllimited="true" ctrlrange="-55 55" joint="FR_KFE"/>

  </actuator>

  <sensor>
      <accelerometer name="Body_Acc" site="imu"/>

      <gyro name="Body_Gyro" site="imu"/>

      <velocimeter name="Body_Vel" site="imu" />

      <framepos name="Body_Pos" objtype="site" objname="imu"/>

      <framequat name="Body_Quat" objtype="site" objname="imu"/>
  </sensor>

</mujoco>
